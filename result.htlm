<!DOCTYPE html>
<html>

<head>

<title>Result</title>

<link rel="stylesheet" href="style.css">

</head>

<body>

<h1>Test Result</h1>

<h2 id="score"></h2>

<script>

let score=localStorage.getItem("score")

document.getElementById("score").innerText="Your Score: "+score

</script>

</body>

</html>
